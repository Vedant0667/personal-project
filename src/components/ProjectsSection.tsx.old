"use client"

import { BentoGrid, BentoGridItem } from "@/components/ui/bento"
import { projects } from "@/data/projects"
import Image from "next/image"

export default function ProjectsSection() {
  // Dynamic layout pattern based on actual image aspect ratios
  const getCardLayout = (index: number) => {
    // Image aspect ratios (from identify command):
    // 0: shelteraid-check (1.00 - square)
    // 1: shelteraidtx-portal (1.96 - wide landscape)
    // 2: thinkclear-frames (1.78 - landscape 16:9)
    // 3: campus-life (0.46 - tall portrait)
    // 4: ftc screenshot (1.55 - landscape)
    // 5: rally-trophy (0.56 - tall portrait)
    // 6: tariffs-paper (0.77 - portrait)
    // 7: vidrant-content (1.25 - landscape)

    // overlayHeight: how much of the bottom should have the black gradient
    // Landscape images need more overlay (h-4/5 = 80%) since they're wider
    // Portrait images need less overlay (h-2/3 = 66%) since they're taller

    if (index === 0) return { className: "md:col-span-2", overlayHeight: "h-3/4" } // Shelter Aid TX - square
    if (index === 1) return { className: "md:col-span-1", overlayHeight: "h-4/5" } // Portal - WIDE landscape, needs more overlay
    if (index === 2) return { className: "md:col-span-1", overlayHeight: "h-4/5" } // THINK Clear - landscape 16:9, needs more overlay
    if (index === 3) return { className: "md:col-span-1 md:row-span-2", overlayHeight: "h-2/3" } // CampusLife - TALL portrait
    if (index === 4) return { className: "md:col-span-2", overlayHeight: "h-4/5" } // FTC - landscape, needs more overlay
    if (index === 5) return { className: "md:col-span-1 md:row-span-2", overlayHeight: "h-2/3" } // Rally - TALL portrait
    if (index === 6) return { className: "md:col-span-1", overlayHeight: "h-3/4" } // Tariffs - portrait
    if (index === 7) return { className: "md:col-span-1", overlayHeight: "h-4/5" } // Content - landscape, needs more overlay

    return { className: "", overlayHeight: "h-3/4" }
  }

  return (
    <div className="w-full bg-black py-20 px-4 md:px-8 lg:px-10">
      <div className="max-w-7xl mx-auto mb-12">
        <h2 className="text-lg md:text-4xl mb-4 text-white max-w-4xl">
          Featured Projects
        </h2>
        <p className="text-neutral-400 text-sm md:text-base max-w-2xl">
          From nonprofits to hardware prototypes, here's what I've been building.
        </p>
      </div>

      <BentoGrid className="max-w-7xl mx-auto">
        {projects.map((project, index) => {
          const { className, overlayHeight } = getCardLayout(index)

          return (
            <BentoGridItem
              key={project.title}
              title={project.title}
              story={project.story}
              bullets={project.bullets}
              links={project.links}
              tags={project.tags}
              className={className}
              overlayHeight={overlayHeight}
              header={
                <div className="absolute inset-0">
                  <Image
                    src={project.imageSrc}
                    alt={project.imageAlt}
                    fill
                    className="object-contain group-hover/bento:scale-105 transition-transform duration-500"
                    sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
                  />
                </div>
              }
            />
          )
        })}
      </BentoGrid>
    </div>
  )
}
